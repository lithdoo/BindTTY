{
  "name": "bindtty-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:examples": "npm run build --workspace @bindtty/example-counter && npm run build --workspace @bindtty/example-form && npm run build --workspace @bindtty/example-log-viewer",
    "test": "npm run test --workspaces --if-present",
    "test:e2e:real": "npm test --workspace @bindtty/e2e",
    "test:e2e:real:env": "npm run env:real --workspace @bindtty/e2e",
    "test:e2e:real:win": "npm run run:real:win --workspace @bindtty/e2e",
    "test:e2e:real:wsl": "npm run run:real:wsl --workspace @bindtty/e2e"
  },
  "engines": {
    "node": ">=18"
  }
}
