{
  "name": "@bindtty/terminal",
  "version": "0.1.0-alpha.10",
  "type": "module",
  "description": "Terminal lifecycle and input host for BindTTY.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build --workspace @bindtty/input && tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "test": "npm run build && tsc -p test/tsconfig.json && node --test test/dist/*.test.js"
  },
  "dependencies": {
    "@bindtty/input": "0.1.0-alpha.10"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lithdoo/BindTTY.git",
    "directory": "packages/terminal"
  },
  "bugs": {
    "url": "https://github.com/lithdoo/BindTTY/issues"
  },
  "homepage": "https://github.com/lithdoo/BindTTY/tree/main/packages/terminal#readme"
}
