{
  "name": "@bindtty/widgets",
  "version": "0.1.0-alpha.3",
  "type": "module",
  "description": "Reusable interactive widgets for BindTTY.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "test": "npm run build --workspace @bindtty/text && npm run build && tsc -p test/tsconfig.json && node --test test/dist/*.test.js"
  },
  "dependencies": {
    "@bindtty/interaction": "0.1.0-alpha.3",
    "@bindtty/signal": "0.1.0-alpha.3",
    "@bindtty/text": "0.1.0-alpha.3",
    "@bindtty/vnode": "0.1.0-alpha.3"
  },
  "peerDependencies": {
    "@bindtty/signal": "0.1.0-alpha.3"
  },
  "peerDependenciesMeta": {
    "@bindtty/signal": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lithdoo/BindTTY.git",
    "directory": "packages/widgets"
  },
  "bugs": {
    "url": "https://github.com/lithdoo/BindTTY/issues"
  },
  "homepage": "https://github.com/lithdoo/BindTTY/tree/main/packages/widgets#readme"
}
